# Google Cloud
GCP_PROJECT_ID=gen-lang-client-0829420978
GCS_BUCKET_NAME=data-connect-27316
# Paste the full service account JSON as a single line for managed deployments.
# For local testing, you can keep this empty and use GOOGLE_APPLICATION_CREDENTIALS=./credentials.json.
GCP_SA_JSON=

# Database (single shared PostgreSQL)
# Local default for docker-compose.local.yml:
#   user=jdboss password=jdboss db=jdboss host=localhost port=5432
DATABASE_URL=postgresql://jdboss:jdboss@localhost:5432/jdboss

# GitHub auth for LangChain GitHubToolkit (pick one):
# 1) Easiest local testing: Personal Access Token (repo scope)
GITHUB_ACCESS_TOKEN=
# 2) Or GitHub App credentials (if you already use app-based auth)
# Create app at: https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPOSITORY=owner/repo  # e.g. ayush27316/JDataBoss
GITHUB_BRANCH=agent/migration # working branch the agent writes to
GITHUB_BASE_BRANCH=main

# xAI Grok
XAI_API_KEY=
XAI_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# Pipeline behaviour
STAGING_THRESHOLD=10          # number of pending files that trigger the agent
PR_MERGE_MODE=manual          # "auto" or "manual"

# Webhook auth (optional but recommended)
PUBSUB_VERIFICATION_TOKEN=    # add ?token=<value> to your Pub/Sub push URL
